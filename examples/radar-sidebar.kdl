// zj-radar — a runnable example layout with the sidebar as a pinned left column.
//
//   zj-radar setup zellij --wasm target/wasm32-wasip1/release/zj_radar.wasm
//   cp examples/radar-sidebar.kdl ~/.config/zellij/layouts/
//   zellij --layout radar-sidebar
//
// This layout expects the `radar` plugin alias in ~/.config/zellij/config.kdl.
// `zj-radar setup zellij --wasm ...` creates it, or you can add it manually:
//
//   plugins { radar location="file:~/.config/zellij/plugins/zj_radar.wasm" { naming "managed" } }
//
// The sidebar is a borderless left column INSIDE a vertical split, OUTSIDE
// `children`, so it survives swap-layout cycling. Two templates are required —
// see the "Can't open a new tab" note in docs/troubleshooting.md (upstream zellij#3247): a
// `children` nested in a split is dropped when Zellij derives new_tab_template,
// so runtime tabs (Ctrl+t n) need a concrete focused `pane` instead.
layout {
    // Tabs defined in this file get their panes via `children`.
    default_tab_template {
        pane split_direction="vertical" {
            pane size=32 borderless=true {
                plugin location="radar" {
                    // Desktop notifications (macOS). Master switch + per-status toggles.
                    // notify true
                    // notify_done true
                    // notify_error true
                    // notify_pending true
                    // notify_when_focused false
                }
            }
            children
        }
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    // Tabs created at runtime (Ctrl+t n) get a CONCRETE focused pane, NOT
    // `children` — otherwise the new tab has no focusable terminal and you
    // "can't open a new tab". To put the column on the RIGHT instead, move the
    // radar pane below `pane focus=true` (and below `children` above).
    new_tab_template {
        pane split_direction="vertical" {
            pane size=32 borderless=true {
                plugin location="radar" {
                    // Desktop notifications (macOS). Master switch + per-status toggles.
                    // notify true
                    // notify_done true
                    // notify_error true
                    // notify_pending true
                    // notify_when_focused false
                }
            }
            pane focus=true
        }
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    // Swap layouts (Alt+[ / Alt+]). A custom layout discards Zellij's built-in
    // swaps, so without these blocks cycling does nothing — and a swap entry
    // that didn't include the rail would swap it away. Every entry below routes
    // through the rail-carrying `ui` template, so each arrangement keeps the
    // left column. See docs/troubleshooting.md → "Alt+] hides the rail".
    tab_template name="ui" {
        pane split_direction="vertical" {
            pane size=32 borderless=true {
                plugin location="radar"
            }
            children
        }
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    swap_tiled_layout name="vertical" {
        ui max_panes=5 {
            pane split_direction="vertical" {
                pane
                pane { children; }
            }
        }
        ui max_panes=8 {
            pane split_direction="vertical" {
                pane { children; }
                pane { pane; pane; pane; pane; }
            }
        }
        ui max_panes=12 {
            pane split_direction="vertical" {
                pane { children; }
                pane { pane; pane; pane; pane; }
                pane { pane; pane; pane; pane; }
            }
        }
    }

    swap_tiled_layout name="horizontal" {
        ui max_panes=4 {
            pane
            pane
        }
        ui max_panes=8 {
            pane {
                pane split_direction="vertical" { children; }
                pane split_direction="vertical" { pane; pane; pane; pane; }
            }
        }
        ui max_panes=12 {
            pane {
                pane split_direction="vertical" { children; }
                pane split_direction="vertical" { pane; pane; pane; pane; }
                pane split_direction="vertical" { pane; pane; pane; pane; }
            }
        }
    }

    swap_tiled_layout name="stacked" {
        ui min_panes=5 {
            pane split_direction="vertical" {
                pane
                pane stacked=true { children; }
            }
        }
    }

    tab name="shell" focus=true {
        pane
    }
}
