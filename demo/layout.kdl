// zj-radar demo — Zellij layout (template).
// `record.sh` substitutes __WASM__ with the built wasm path and __ROOT__ with
// the repo root, then writes the concrete layout to target/demo/layout.kdl.
// Four tabs, each running a scripted demo agent; the radar sidebar is pinned
// left in every tab. Uses a direct `file:` plugin path with inline config (no
// alias) so the layout is self-contained.

layout {
    default_tab_template {
        pane split_direction="vertical" {
            pane size=34 borderless=true {
                plugin location="file:__WASM__" {
                    glyphs "nerd"
                    density "cards"
                    naming "managed"
                }
            }
            children
        }
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    // Runtime tabs (Ctrl+t n — handy when exploring the demo live) get a clean
    // bash prompt via demorc.sh, instead of the recording host's shell config.
    new_tab_template {
        pane split_direction="vertical" {
            pane size=34 borderless=true {
                plugin location="file:__WASM__" {
                    glyphs "nerd"
                    density "cards"
                    naming "managed"
                }
            }
            pane focus=true {
                command "bash"
                args "--rcfile" "__ROOT__/demo/demorc.sh" "-i"
            }
        }
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    // The demo OPENS focused on `web` (below) — this tab works in the rail's
    // background, then blocks on approval; the tape jumps here for beat 3.
    tab name="api" {
        pane command="__ROOT__/demo/agent.sh" {
            args "claude" "api" "feat/auth" "needs-you"
        }
    }
    // Two agents in one tab → the rail rolls them up and expands them as a
    // tree (├/└). Focused first so the tree is on screen from the open.
    tab name="web" focus=true {
        pane split_direction="horizontal" {
            pane command="__ROOT__/demo/agent.sh" {
                args "claude" "web" "fix/login" "form"
            }
            pane command="__ROOT__/demo/agent.sh" {
                args "claude" "web" "fix/login" "suite"
            }
        }
    }
    tab name="tests" {
        pane command="__ROOT__/demo/agent.sh" {
            args "test" "core" "main" "tests"
        }
    }
    tab name="infra" {
        pane command="__ROOT__/demo/agent.sh" {
            args "deploy" "infra" "main" "deploy-error"
        }
    }
}
