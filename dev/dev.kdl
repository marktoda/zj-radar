// Dev layout for hot-reloading the zj-radar sidebar plugin.
//
// Build first (needs a wasm32-wasip1 toolchain — see docs/TOOLCHAIN.md):
//   nix develop -c cargo build --target wasm32-wasip1
// Then:
//   zellij --layout dev/dev.kdl
//
// The sidebar is a pinned, borderless left column inside default_tab_template,
// OUTSIDE `children`, so swap_tiled_layout cycling never disturbs it. The
// bottom status-bar is kept (mode/keybind hints); the top compact-bar is
// intentionally absent (the sidebar replaces it).
layout {
    default_tab_template {
        pane split_direction="vertical" {
            pane size=24 borderless=true {
                plugin location="file:/Users/mark.toda/dev/zj-radar/target/wasm32-wasip1/debug/zj_radar.wasm" {
                    // Opt-in: rename tabs even when they have an explicit name.
                    naming "force"
                }
            }
            children
        }
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    // Tabs intentionally UNNAMED → Zellij gives them default "Tab #N" names so
    // auto-naming is visible even without naming "force".
    tab focus=true {
        pane
    }

    tab {
        pane split_direction="vertical" {
            pane
            pane
        }
    }

    tab {
        pane
    }
}
