// Dev layout for dogfooding the zj-radar sidebar plugin.
//
// Build first (needs a wasm32-wasip1 toolchain — see docs/TOOLCHAIN.md):
//   ./dev/build.sh
// Then:
//   ./dev/start.sh
//
// NOTE: the plugin `location` below is RELATIVE to Zellij's working directory
// (Zellij resolves plugin paths against its own cwd, not the layout file), so it
// carries no absolute/usernamed prefix. Launch from the repo root and it just
// works:
//   cd <your-checkout> && ./dev/start.sh
// If you start Zellij from elsewhere the relative path won't resolve — cd to the
// repo root first, or use an absolute path.
//
// Note: Zellij 0.44's `start-or-reload-plugin` opens a second pane for plugins
// created by a layout. `./dev/reload.sh` is only a compatibility wrapper around
// `./dev/build.sh`; restart the dev layout/session to pick up changes.
//
// The sidebar is a pinned, borderless left column inside default_tab_template,
// OUTSIDE `children`, so swap_tiled_layout cycling never disturbs it. The
// bottom status-bar is kept (mode/keybind hints); the top compact-bar is
// intentionally absent (the sidebar replaces it).
layout {
    default_tab_template {
        pane split_direction="vertical" {
            pane size=32 borderless=true {
                plugin location="file:target/wasm32-wasip1/debug/zj_radar.wasm" {
                    // Opt-in: rename tabs even when they have an explicit name.
                    naming "force"
                }
            }
            children
        }
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    // Runtime tabs (Ctrl+t n) need an explicit new_tab_template with a CONCRETE
    // `pane focus=true` — NOT `children`. Zellij drops a `children` nested in a
    // split when it derives new_tab_template (upstream zellij#3247), leaving a
    // tab of only borderless plugin panes with no focusable terminal ("can't
    // open a new tab"). Full rationale: README → "Why two templates?".
    new_tab_template {
        pane split_direction="vertical" {
            pane size=32 borderless=true {
                plugin location="file:target/wasm32-wasip1/debug/zj_radar.wasm" {
                    naming "force"
                }
            }
            pane focus=true
        }
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    // Start with one plain terminal tab. New tabs still use new_tab_template
    // above, so every tab opened while dogfooding keeps the sidebar + status-bar
    // and gets a focusable terminal pane.
    tab focus=true {
        pane
    }
}
