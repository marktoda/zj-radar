// Dev layout template for dogfooding the zj-radar sidebar plugin.
//
// Normal path:
//   ./dev/run.sh
//
// `dev/run.sh` builds the wasm and writes target/dev/dev.kdl with an absolute
// plugin path. From a normal terminal it restarts `zj-radar-dev`; from inside
// Zellij the default command leaves the current session unchanged.
// Keeping this source layout relative makes it readable while avoiding hardcoded
// home paths.
//
// Note: Zellij 0.44's plugin reload actions can open an extra tiled plugin pane
// when the target plugin was created by a layout and is non-selectable, so the
// dev loop avoids in-place sidebar reloads.
//
// The sidebar is a pinned, borderless left column inside default_tab_template,
// OUTSIDE `children`, so swap_tiled_layout cycling never disturbs it. The
// bottom status-bar is kept (mode/keybind hints); the top compact-bar is
// intentionally absent (the sidebar replaces it).
layout {
    default_tab_template {
        pane split_direction="vertical" {
            pane size=32 borderless=true {
                plugin location="file:target/wasm32-wasip1/debug/zj_radar.wasm" {
                    // Opt-in: rename tabs even when they have an explicit name.
                    naming "force"
                }
            }
            children
        }
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    // Runtime tabs (Ctrl+t n) need an explicit new_tab_template with a CONCRETE
    // `pane focus=true` — NOT `children`. Zellij drops a `children` nested in a
    // split when it derives new_tab_template (upstream zellij#3247), leaving a
    // tab of only borderless plugin panes with no focusable terminal ("can't
    // open a new tab"). Full rationale: README → "Why two templates?".
    new_tab_template {
        pane split_direction="vertical" {
            pane size=32 borderless=true {
                plugin location="file:target/wasm32-wasip1/debug/zj_radar.wasm" {
                    naming "force"
                }
            }
            pane focus=true
        }
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    // Start with one plain terminal tab. New tabs still use new_tab_template
    // above, so every tab opened while dogfooding keeps the sidebar + status-bar
    // and gets a focusable terminal pane.
    tab focus=true {
        pane
    }
}
