// Dev layout for hot-reloading the zj-radar sidebar plugin.
//
// Build first (needs a wasm32-wasip1 toolchain — see docs/TOOLCHAIN.md):
//   nix develop -c cargo build --target wasm32-wasip1
// Then:
//   zellij --layout dev/dev.kdl
//
// NOTE: the plugin `location` below is an absolute path to THIS checkout's
// debug artifact. Zellij resolves plugin paths relative to its own cwd, not the
// layout file, so a relative path is unreliable here. If you cloned elsewhere,
// update the path to <your-checkout>/target/wasm32-wasip1/debug/zj_radar.wasm.
//
// The sidebar is a pinned, borderless left column inside default_tab_template,
// OUTSIDE `children`, so swap_tiled_layout cycling never disturbs it. The
// bottom status-bar is kept (mode/keybind hints); the top compact-bar is
// intentionally absent (the sidebar replaces it).
layout {
    default_tab_template {
        pane split_direction="vertical" {
            pane size=24 borderless=true {
                plugin location="file:/Users/mark.toda/dev/zj-radar/target/wasm32-wasip1/debug/zj_radar.wasm" {
                    // Opt-in: rename tabs even when they have an explicit name.
                    naming "force"
                }
            }
            children
        }
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    // Explicit new_tab_template for tabs created at runtime (Ctrl+t n / NewTab).
    //
    // WHY THIS EXISTS: without it, Zellij DERIVES the new-tab layout from
    // default_tab_template — and that derivation drops a `children` placeholder
    // nested inside a sub-split (which our sidebar column requires; see upstream
    // zellij-org/zellij#3247). The new tab then contains ONLY borderless plugin
    // panes (the radar sidebar is set_selectable(false) + the status-bar), i.e.
    // NO focusable terminal: focus has nowhere to land, the mode indicator
    // sticks, and keystrokes fall through — "can't open a new tab at all".
    //
    // FIX: declare new_tab_template explicitly with a concrete, focused terminal
    // `pane` instead of `children`. Runtime tabs have no pre-existing children to
    // slot, so a real pane is both more correct AND survives the derivation.
    new_tab_template {
        pane split_direction="vertical" {
            pane size=24 borderless=true {
                plugin location="file:/Users/mark.toda/dev/zj-radar/target/wasm32-wasip1/debug/zj_radar.wasm" {
                    naming "force"
                }
            }
            pane focus=true
        }
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    // Tabs intentionally UNNAMED → Zellij gives them default "Tab #N" names so
    // auto-naming is visible even without naming "force".
    tab focus=true {
        pane
    }

    tab {
        pane split_direction="vertical" {
            pane
            pane
        }
    }

    tab {
        pane
    }
}
